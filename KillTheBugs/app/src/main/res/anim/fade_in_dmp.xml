<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android" android:shareInterpolator="false">
    <!-- change fromXScale, toXScale, fromYScale and toYScale to 1.0 to see what's going on with admin panel -->
    <scale
        android:interpolator="@android:anim/accelerate_decelerate_interpolator"
        android:fromXScale="6.0"
        android:toXScale="6.0"
        android:fromYScale="6.0"
        android:toYScale="6.0"
        android:pivotX="5%"
        android:pivotY="105%"
        android:fillAfter="false"
        android:duration="2999"
        android:repeatCount="1"
        android:zAdjustment="top"/>

    <!-- change fromAlpha and toAlpha to 0.5 to see whats going on with admin panel -->
    <alpha
        android:fromAlpha="0.5"
        android:toAlpha="0.5"
        android:repeatCount="1"
        android:duration="6000" />

</set>